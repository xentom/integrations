{
  "$schema": "https://assets.xentom.com/schemas/package.json",
  "name": "@xentom/template",
  "version": "0.1.0",
  "displayName": "Template",
  "description": "This is a template for creating new integrations in the Xentom ecosystem. It includes basic setup and configuration.",
  "categories": [],
  "homepage": "https://xentom.com/integrations/xentom/template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xentom/integrations.git",
    "directory": "packages/template"
  },
  "bugs": {
    "url": "https://github.com/xentom/integrations/issues"
  },
  "type": "module",
  "icon": "./assets/icon.webp",
  "main": "./build/index.js",
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo node_modules build dist",
    "dev": "xentom dev",
    "build": "xentom build",
    "pack": "xentom pack",
    "publish": "xentom publish"
  },
  "dependencies": {
    "@xentom/integration-framework": "catalog:",
    "valibot": "catalog:"
  }
}
