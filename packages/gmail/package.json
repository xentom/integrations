{
  "$schema": "https://assets.xentom.com/schemas/package.json",
  "name": "@xentom/gmail",
  "version": "0.1.1",
  "displayName": "Gmail",
  "description": "Gmail integration for the Xentom workflow editor. Send, receive, and manage emails through Gmail's API with powerful workflow automation capabilities.",
  "categories": [
    "Experimental",
    "Messaging"
  ],
  "homepage": "https://xentom.com/integrations/xentom/gmail",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xentom/integrations.git",
    "directory": "packages/gmail"
  },
  "bugs": {
    "url": "https://github.com/xentom/integrations/issues"
  },
  "type": "module",
  "icon": "./assets/icon.webp",
  "main": "./build/index.js",
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo node_modules build dist",
    "dev": "xentom dev",
    "build": "xentom build",
    "pack": "xentom pack"
  },
  "dependencies": {
    "@xentom/integration-framework": "catalog:",
    "gaxios": "^7.0.0",
    "google-auth-library": "10.5.0",
    "googleapis": "catalog:",
    "valibot": "catalog:"
  }
}
