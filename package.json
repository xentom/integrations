{
  "name": "@xentom/integrations",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.2.18",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xentom/integrations.git"
  },
  "bugs": {
    "url": "https://github.com/xentom/integrations/issues"
  },
  "scripts": {
    "clean": "turbo run clean && git clean -xdf .turbo node_modules",
    "lint": "turbo run lint --continue --",
    "typecheck": "turbo typecheck --continue",
    "format": "turbo run format --continue",
    "build": "turbo run build --",
    "pack": "turbo run pack --",
    "publish": "turbo run publish --",
    "test": "turbo run test --continue",
    "update": "bun update -i -r"
  },
  "devDependencies": {
    "@xentom/integration-framework": "catalog:",
    "@biomejs/biome": "catalog:",
    "@xentom/style-guide": "*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.10",
    "typescript": "catalog:"
  },
  "overrides": {
    "google-auth-library": "10.5.0"
  },
  "patchedDependencies": {
    "cpu-features@0.0.10": "patches/cpu-features@0.0.10.patch",
    "ts3-nodejs-library@3.5.1": "patches/ts3-nodejs-library@3.5.1.patch"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "@xentom/integration-framework": "^0.0.21",
      "@xentom/style-guide": "*",
      "@types/bun": "^1.3.9",
      "mime": "^4.0.7",
      "googleapis": "^171.4.0",
      "valibot": "^1.2.0",
      "@biomejs/biome": "^2.4.4",
      "typescript": "^5.9.3"
    }
  }
}
